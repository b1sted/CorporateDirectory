# DATABASE CONFIGURATION
DB_NAME=corporate_directory_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# SPRING SECURITY
SPRING_SECURITY_USER_NAME=spring
SPRING_SECURITY_USER_PASSWORD=your_secure_password_here